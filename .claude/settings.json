{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(secrets/**)",
      "Read(**/secrets/**)",
      "Read(config/credentials.json)",
      "Read(**/credentials.json)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ]
  }
}
